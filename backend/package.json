{
  "name": "@my-city/backend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "start": "node dist/main.js",
    "start:dev": "nest start --watch",
    "build": "nest build",
    "lint": "tsc --noEmit",
    "test": "jest --config ./jest.config.js --passWithNoTests",
    "test:e2e": "jest --config ./test/jest-e2e.json --runInBand",
    "typeorm": "node --env-file-if-exists=.env ../node_modules/typeorm/cli.js -d src/database/data-source.ts",
    "migration:run": "node --env-file-if-exists=.env -r ts-node/register ../node_modules/typeorm/cli.js -d src/database/data-source.ts migration:run",
    "migration:revert": "node --env-file-if-exists=.env -r ts-node/register ../node_modules/typeorm/cli.js -d src/database/data-source.ts migration:revert",
    "seed": "node --env-file-if-exists=.env -r ts-node/register src/database/seed.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1045.0",
    "@aws-sdk/s3-request-presigner": "^3.1045.0",
    "@nestjs/common": "^11.0.3",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.0.3",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/passport": "^11.0.3",
    "@nestjs/platform-express": "^11.0.3",
    "@nestjs/swagger": "^11.3.0",
    "@nestjs/throttler": "^6.2.1",
    "@nestjs/typeorm": "^11.0.0",
    "bcryptjs": "^2.4.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "firebase-admin": "^13.0.2",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.13.1",
    "redis": "^4.7.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "typeorm": "^0.3.20",
    "uuid": "^11.0.5"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.2",
    "@nestjs/schematics": "^11.0.1",
    "@nestjs/testing": "^11.0.3",
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.2",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^6.0.2",
    "jest": "^29.7.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.2"
  }
}
